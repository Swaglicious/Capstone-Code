#!/usr/bin/env python

import RPi.GPIO as GPIO
from mfrc522 import SimpleMFRC522
import os
import time
import subprocess

reader = SimpleMFRC522()

# Variables for files
visual_files = {
    551721708274: "/home/campse/caps/env/one.mp4",
    207537121893: "/home/campse/caps/env/two.mp4",
    482431805988: "/home/campse/caps/env/three.mp3"
}

# Looping background video
looping_video = "/home/campse/caps/env/loop.mp4"  # Replace with your looping video path

try:
    print("Scan Item For Clue.....")

    # Start looping background video in VLC
    loop_process = subprocess.Popen([
        "cvlc", "--loop", "--fullscreen", "--no-video-title-show", "--quiet", looping_video
    ])
    
    while True:
        id = reader.read()[0]
        print("RFID Detected:", id)
        
        if id in visual_files:
            file_path = visual_files[id]
            print("Playing Clue For Item:", id)
            
            # Stop the looping video
            loop_process.terminate()
            loop_process.wait()
            
            # Play the selected media
            if file_path.endswith(".mp4"):
                os.system(f"cvlc --fullscreen --play-and-exit --no-video-title-show '{file_path}'")
            elif file_path.endswith(".mp3"):
                os.system(f"mpg321 '{file_path}'")
            else:
                print("File Unsupported:", file_path)
            
            # Resume looping video after clue finishes
            loop_process = subprocess.Popen([
                "cvlc", "--loop", "--fullscreen", "--no-video-title-show", "--quiet", looping_video
            ])
        else:
            print("Clue Not Found. Try Again.")
        
        time.sleep(0.5)  # Small delay to prevent rapid re-reading

finally:
    GPIO.cleanup()
    # Ensure looping video is stopped on exit
    loop_process.terminate()
    loop_process.wait()
